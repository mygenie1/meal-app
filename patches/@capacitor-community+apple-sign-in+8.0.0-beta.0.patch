+// ★ PATCH(siktakilgi): presentationContextProvider 미설정 상태였음 — Apple 권장대로
+//   프레젠테이션 앵커(윈도우)를 명시적으로 제공해서 멀티씬/WebView 환경에서의
+//   불안정성을 줄인다. Capacitor 브리지의 루트 뷰컨트롤러 윈도우를 사용.
+extension SignInWithApple: ASAuthorizationControllerPresentationContextProviding {
+    public func presentationAnchor(for controller: ASAuthorizationController) -> ASPresentationAnchor {
+        if let window = self.bridge?.viewController?.view.window {
+            return window
+        }
+        // ★ PATCH(siktakilgi): view.window 가 nil일 때 ASPresentationAnchor()(빈 UIWindow)로
+        //   폴백하면 어떤 scene에도 속하지 않은 유령 윈도우가 생긴다. 시스템 인증(AuthKit)은
+        //   내부적으로 자격을 성공적으로 준비했다고 로그를 남기지만(맥 Console "Successfully
+        //   created"), 그 유령 윈도우엔 실제로 표시할 화면이 없어 사용자가 상호작용할 수
+        //   없고 결국 델리게이트가 1001("작업을 완료할 수 없음")을 받는다.
+        //   → 연결된 scene들 중 foreground-active 상태의 key window를 직접 찾아 진짜
+        //   앵커를 반환한다.
+        if let activeWindow = UIApplication.shared.connectedScenes
+            .compactMap({ $0 as? UIWindowScene })
+            .first(where: { $0.activationState == .foregroundActive })?
+            .windows
+            .first(where: { $0.isKeyWindow }) {
+            return activeWindow
+        }
+        // 최후의 폴백: foreground-active scene을 못 찾았어도, 빈 UIWindow보다는
+        // 연결된 scene 중 실제로 존재하는 윈도우를 쓰는 편이 안전하다.
+        if let anyWindow = UIApplication.shared.connectedScenes
+            .compactMap({ $0 as? UIWindowScene })
+            .flatMap({ $0.windows })
+            .first {
+            return anyWindow
+        }
+        return ASPresentationAnchor()
     }
 }
